# Environment
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.uv/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Obsidian workspace files — local UI state, not shared
.obsidian/workspace.json
.obsidian/workspace-mobile.json
wiki/.obsidian/workspace.json
wiki/.obsidian/workspace-mobile.json

# Large raw inputs — keep PDFs out of git
raw/pdfs/*.pdf
raw/pdfs/*.PDF

# DuckDB index (rebuild from wiki/)
*.duckdb
*.duckdb.wal

# macOS
.DS_Store

# VS Code
.vscode/

# Claude Code — machine-specific settings only
.claude/settings.local.json
# Ephemeral planning docs — canonical knowledge belongs in wiki/
.claude/docs/
# Playground skills toolkit copies accidentally nested here — exclude until relocated
.claude/skills/skills/
.claude/skills/old/

# Node
node_modules/
**/node_modules/

# Vite cache artifacts
**/.vite/
