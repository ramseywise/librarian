{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/wiki-lint.sh",
            "timeout": 10,
            "statusMessage": "Checking wiki page..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(xargs *)",
      "Bash(diff *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(python3 *)",
      "Bash(git *)",
      "Bash(uv run *)",
      "Bash(ls *)"
    ]
  },
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "linear-mcp-server"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    },
    "librarian": {
      "command": "uv",
      "args": ["run", "python", "app/mcp_server/server.py"],
      "cwd": "/Users/ramsey.wise/Workspace/librarian",
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    }
  }
}
