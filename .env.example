# Librarian — environment variables
# Copy to .env and fill in required values

# --- LLM ---
GOOGLE_API_KEY=              # required — used by the chat agent (aistudio.google.com)
# GEMINI_MODEL=gemini-2.0-flash

# ANTHROPIC_API_KEY=         # only needed if researcher agent is migrated back to Anthropic
#                            # (researcher currently uses core.client which is not present —
#                            #  migrate researcher to Gemini before use)

# --- Notion integration ---
NOTION_API_KEY=

# --- Linear integration ---
LINEAR_API_KEY=
LINEAR_PROJECT_ID=           # default project ID for ingest_linear (overrideable with --project)

# --- Local paths ---
OBSIDIAN_VAULT=~/Obsidian                  # required by researcher agent — path to your Obsidian vault
DROPBOX_PDF_PATH=~/Dropbox/research-pdfs   # directory of research PDFs for ingest_pdf
PLAYGROUND_PATH=~/Workspace/playground     # path to playground repo for seed_from_playground

# --- Researcher agent tuning (optional) ---
# RESEARCH_MAX_TOKENS=4096
# RESEARCH_CRON_MAX_TOKENS=4096
# RESEARCH_CRON_MAX_PDFS=5
