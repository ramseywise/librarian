# LLM — cloud
ANTHROPIC_API_KEY=          # used by ingest scripts and MCP server
GOOGLE_API_KEY=             # used by the graph UI chat agent (get one free at aistudio.google.com)
GEMINI_MODEL=gemini-2.0-flash  # override to use a different Gemini model

# Notion integration
NOTION_API_KEY=
NOTION_TARGET_PAGE_ID=   # Parent page ID for wiki exports

# Linear integration
LINEAR_API_KEY=
LINEAR_PROJECT_ID=       # Project ID for ticket exports

# Local paths
DROPBOX_PDF_PATH=~/Dropbox/research-pdfs   # Directory of research PDFs
PLAYGROUND_PATH=~/Workspace/playground     # Path to playground repo for seeding
