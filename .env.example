# LLM — cloud (used by ingest scripts and MCP server)
ANTHROPIC_API_KEY=

# Ollama — local inference for the graph API chat agent
OLLAMA_MODEL=llama3.2        # or qwen2.5:7b for better tool use
OLLAMA_HOST=http://localhost:11434  # override if running Ollama on another machine

# Notion integration
NOTION_API_KEY=
NOTION_TARGET_PAGE_ID=   # Parent page ID for wiki exports

# Linear integration
LINEAR_API_KEY=
LINEAR_PROJECT_ID=       # Project ID for ticket exports

# Local paths
DROPBOX_PDF_PATH=~/Dropbox/research-pdfs   # Directory of research PDFs
PLAYGROUND_PATH=~/Workspace/playground     # Path to playground repo for seeding
